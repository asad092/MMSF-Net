        print()
        print(f"Predictions: ", end="")
        for i, disease in enumerate(diseases):
            status = "DETECTED" if preds[0][i] == 1 else "healthy"
            print(f"{disease}: {status} ", end="")
        print()
        print(f"True labels: ", end="")
        for i, disease in enumerate(diseases):
            status = "DETECTED" if sample['label'][i] == 1 else "healthy"
            print(f"{disease}: {status} ", end="")

def generate_synthetic_data(n_samples=24312, test_ratio=0.15, val_ratio=0.15):
    """
    Generate synthetic multi-modal cattle disease data for testing.
    In practice, replace with real sensor data.
    """
    print("Generating synthetic multi-modal cattle disease data...")
    
    n_features = {
        'accel': (100, 3),   # 10s @ 10Hz, 3 axes
        'gyro': (100, 3),    # 10s @ 10Hz, 3 axes
        'temp': (3,),        # current, change, trend
        'audio': (13, 100),  # MFCC: 13 coeffs, 100 frames
        'gps': (3,),         # lat, lon, alt
        'thermal': (32, 24)  # thermal image
    }
    
    # Generate random features
    accel = np.random.randn(n_samples, *n_features['accel']).astype(np.float32)
    gyro = np.random.randn(n_samples, *n_features['gyro']).astype(np.float32)
    temp = np.random.randn(n_samples, *n_features['temp']).astype(np.float32) * 0.5 + 38.5  # around 38.5°C
    audio = np.random.randn(n_samples, *n_features['audio']).astype(np.float32) * 0.3
    gps = np.random.randn(n_samples, *n_features['gps']).astype(np.float32) * 0.01
    thermal = np.random.randn(n_samples, *n_features['thermal']).astype(np.float32) * 2 + 38
    
    # Generate imbalanced labels (78% healthy, 22% disease)
    n_disease = int(n_samples * 0.22)
    labels = np.zeros((n_samples, 4), dtype=np.float32)
    
    # Assign disease labels
    disease_indices = np.random.choice(n_samples, n_disease, replace=False)
    
    for idx in disease_indices:
        disease_type = np.random.randint(0, 4)
        labels[idx, disease_type] = 1
    
    # Add some signal to make patterns learnable
    for i, idx in enumerate(disease_indices):
        disease_type = int(np.argmax(labels[idx]))
        if disease_type == 0:  # Mastitis: higher temp
            temp[idx] += 1.5
        elif disease_type == 1:  # Lameness: more accel variation
            accel[idx] += np.random.randn(100, 3) * 0.5
        elif disease_type == 2:  # Ketosis: temp + slight accel change
            temp[idx] += 1.0
            accel[idx] += np.random.randn(100, 3) * 0.3
        elif disease_type == 3:  # Respiratory: audio pattern change
            audio[idx] += np.random.randn(13, 100) * 0.5
    
    # Split data
    n_total = n_samples
    n_test = int(n_total * test_ratio)
    n_val = int(n_total * val_ratio)
    n_train = n_total - n_test - n_val
    
    indices = np.random.permutation(n_total)
    train_idx = indices[:n_train]
    val_idx = indices[n_train:n_train+n_val]
    test_idx = indices[n_train+n_val:]
    
    train_dataset = CattleDiseaseDataset(
        accel[train_idx], gyro[train_idx], temp[train_idx],
        audio[train_idx], gps[train_idx], thermal[train_idx],
        labels[train_idx]
    )
    
    val_dataset = CattleDiseaseDataset(
        accel[val_idx], gyro[val_idx], temp[val_idx],
        audio[val_idx], gps[val_idx], thermal[val_idx],
        labels[val_idx]
    )
    
    test_dataset = CattleDiseaseDataset(
        accel[test_idx], gyro[test_idx], temp[test_idx],
        audio[test_idx], gps[test_idx], thermal[test_idx],
        labels[test_idx]
    )
    
    print(f"Train: {len(train_dataset)}, Val: {len(val_dataset)}, Test: {len(test_dataset)}")
    
    return train_dataset, val_dataset, test_dataset



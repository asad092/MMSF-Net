    print("MODEL TRAINING COMPLETE")
    print("="*60)
    print(f"Test Accuracy:  {test_metrics['accuracy']:.4f}")
    print(f"Test Precision: {test_metrics['precision']:.4f}")
    print(f"Test Recall:    {test_metrics['recall']:.4f}")
    print(f"Test F1-Score:  {test_metrics['f1']:.4f}")
    print(f"Test AUC-ROC:   {test_metrics['auc_roc']:.4f}")
    print(f"Model Size:     {model.get_model_size():.2f} KB")
    print("="*60)
    
    # Example inference
    print("\nExample inference on single sample:")
    model.eval()
    sample = test_dataset[0]
    
    with torch.no_grad():
        accel = sample['accel'].unsqueeze(0).to(device)
        gyro = sample['gyro'].unsqueeze(0).to(device)
        temp = sample['temp'].unsqueeze(0).to(device)
        audio = sample['audio'].unsqueeze(0).to(device)
        gps = sample['gps'].unsqueeze(0).to(device)
        thermal = sample['thermal'].unsqueeze(0).to(device)
        
        probs = model(accel, gyro, temp, audio, gps, thermal)
        preds = (probs >= 0.5).float()
        
        diseases = ['Mastitis', 'Lameness', 'Ketosis', 'Respiratory']
        print(f"Probabilities: ", end="")
        for i, disease in enumerate(diseases):
